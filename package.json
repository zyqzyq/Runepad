  "type": "module",
  "scripts": {
    "dev": "vite",
    "pack:msix": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/pack-msix.ps1",
    "pack:msix:store": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/pack-msix.ps1 -Store -SkipSigning",
    "msix:dev-cert": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/windows/create-msix-dev-cert.ps1",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "e2e": "playwright test"
  },
